<Window x:Class="rocnikovy_projekt.MainWindow"
        WindowState="Maximized" 
WindowStyle="None" 
ResizeMode="NoResize"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rocnikovy_projekt"
        mc:Ignorable="d"
        Title="Polda: Útěk z vězení" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Viewbox Stretch="Fill">
        <Grid Width="1000" Height="600" Cursor="">

            <Image Source="images/image40.png" Stretch="Fill"/>

            <Canvas>
                <Button Canvas.Left="740" Canvas.Top="750" Width="180" Height="100" 
                        Opacity="0" Cursor="Hand"
                        Tag="Tam je kanal pres ktery se da uniknout." Click="OnHotspotClick"/>

                <Button Canvas.Left="830" Canvas.Top="130" Width="120" Height="180" 
                        Opacity="0" Cursor="Hand"
                        Tag="Plakát Marie... vypadá to, že za ním něco je." Click="OnHotspotClick"/>

                <Button Canvas.Left="450" Canvas.Top="180" Width="120" Height="100" 
                        Opacity="0" Cursor="Hand"
                        Tag="Ty mříže jsou pořádně rezavé." Click="OnHotspotClick"/>

                <Button Canvas.Left="470" Canvas.Top="630" Width="80" Height="100" 
                        Opacity="0" Cursor="Hand"
                        Tag="Stará dřevěná stolička. Možná by se dala použít jako stupátko." Click="OnHotspotClick"/>

                <Button Canvas.Left="400" Canvas.Top="850" Width="120" Height="60" 
                        Opacity="0" Cursor="Hand"
                        Tag="Pevné lano. To by se při útěku mohlo hodit." Click="OnHotspotClick"/>
            </Canvas>
            <Border Name="DialogBox" 
        Background="#CCF8DC00" 
        BorderBrush="DimGray" 
        BorderThickness="2" 
        CornerRadius="5" 
        Width="300" Height="100" 
        HorizontalAlignment="Right" VerticalAlignment="Top" 
        Margin="0,50,50,0" 
        Visibility="Collapsed">

                <TextBlock Name="DialogText" 
               TextWrapping="Wrap" 
               Margin="10" 
               FontFamily="Ink Free" 
               FontSize="16" 
               FontWeight="Bold" 
               Foreground="DarkSlateGray"/>
            </Border>
            <Button Content="Zpět do menu" HorizontalAlignment="Left" VerticalAlignment="Top" Click="ZpetMenu_Click"/>
        </Grid>
    </Viewbox>
</Window>